
Za vsako točko @"A"@ določite kvadrant, ki mu pripada, in koordinate 
@center@ točke @"M"@, ki je simetrična glede na @"x"@ os, 
@center@ točke @"N"@, ki je simetrične glede na @"y"@ os, 
 na točko @"A"@.
@repeat(3)@ 
@vspace@
@center@ @"A"@ = (@xa@, @ya@) @hspacept(15)@ kvadrant @hspacept(3)@ @lib.check_one_option_dropdown(posit, posit[ind])@
@center@ @"M"@ = (@lib.check_number(xm,25)@, @lib.check_number(ym,15)@), @hspacept(5)@ @"N"@ = (@lib.check_number(xn,25)@, @lib.check_number(yn,15)@) 
@/repeat@    
            